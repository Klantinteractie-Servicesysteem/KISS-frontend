# The environment settings for this application in Docker

APP_NAME=KISS Frontend
APP_VERSION=v1
APP_ENV=dev
APP_BUILD=dev

# The container settings for this application. these are in this file because they are used in the docker-compose.deploy.yaml file.
# we probably want to simplify the build process in the future by moving these to the github workflow file and removing the docker-compose.deploy.yaml file alltogether.
CONTAINER_REGISTRY_BASE=ghcr.io/klantinteractie-servicesysteem
CONTAINER_PROJECT_NAME=kiss-frontend

# specific settings for the front end / vite
VITE_API_REFRESH_INTERVAL_MS=20000
BFF_SSL_PORT=7231
POSTGRES_PORT=5432
POSTGRES_HOST=postgres-db
ENTERPRISE_SEARCH_ENGINE=kiss-engine
ORGANISATIE_IDS=999990639
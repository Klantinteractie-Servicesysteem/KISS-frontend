{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "aspire",
      "request": "launch",
      "name": "Aspire: Launch default AppHost",
      "program": "${workspaceFolder}"
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    },
    {
      "name": "Debug Playwright Tests",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": ["test", "--filter", "VragenAnonymousContactMoment"],
      "cwd": "${workspaceFolder}/Kiss.Bff.EndToEndTest",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "HEADED": "1"
      }
    }
  ]
}
